*.pb.go
!proto/**/*.pb.go
*_grpc.pb.go
!proto/**/*_grpc.pb.go

# gRPC Gateway generated files
*.gw.go
!proto/**/*.gw.go

# Swagger/OpenAPI generated files
swagger.json
swagger.yaml
apidocs.json

